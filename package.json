{
    "name": "digital-terrain-model-viewer",
    "version": "1.0.0",
    "description": "Interactive terrain analysis and visualization of Digital Terrain Models in the browser.",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:deploy": "tsc && vite build --base=/apps/digital-terrain-model-viewer/",
        "deploy": "npm run build:deploy && node scripts/deploy.mjs",
        "preview": "vite preview",
        "preview:deploy": "vite preview --base=/apps/digital-terrain-model-viewer/",
        "typecheck": "tsc --noEmit",
        "postinstall": "node scripts/patch-design-tokens.js"
    },
    "dependencies": {
        "@jwrae/design-tokens": "^1.0.0",
        "@types/proj4": "^2.5.6",
        "geotiff": "^2.1.3",
        "lucide": "^0.446.0",
        "ol": "^10.3.1",
        "proj4": "^2.20.4"
    },
    "devDependencies": {
        "typescript": "^5.7.0",
        "vite": "^6.0.0"
    }
}